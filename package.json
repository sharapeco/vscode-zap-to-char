{
	"name": "zaptochar",
	"displayName": "zap-to-char",
	"description": "zap-to-char for Visual Studio Code",
	"publisher": "sharapeco",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/sharapeco/vscode-zap-to-char/"
	},
	"icon": "assets/icon.png",
	"galleryBanner": {
		"color": "#3a3d41",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.46.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"emacs",
		"xyzzy",
		"zap",
		"cursor"
	],
	"activationEvents": [
		"*"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "zaptochar.forward",
				"title": "Zap to char: Jump forward"
			},
			{
				"command": "zaptochar.backward",
				"title": "Zap to char: Jump backward"
			},
			{
				"command": "zaptochar.deleteForward",
				"title": "Zap to char: Delete forward"
			},
			{
				"command": "zaptochar.deleteBackward",
				"title": "Zap to char: Delete backward"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm run compile",
		"compile": "tsc -p ./",
		"lint": "biome check --max-diagnostics 20",
		"lint:fix": "biome check --max-diagnostics 20 --write",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm run compile && pnpm run lint",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/glob": "8.0.0",
		"@types/mocha": "10.0.0",
		"@types/node": "^13.11.0",
		"@types/vscode": "1.72.0",
		"@vscode/test-electron": "^2.5.2",
		"ansi-regex": "~5.0.1",
		"glob": "13.0.6",
		"mocha": "^11.7.5",
		"typescript": "4.8.4"
	},
	"pnpm": {
		"overrides": {
			"serialize-javascript": "7.0.3"
		}
	}
}
